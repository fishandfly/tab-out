{
  "name": "tab-out",
  "version": "1.0.0",
  "description": "把新标签页变成集 GTD、白板、笔记、结构图于一体的工作台。",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "node --test extension/tests/*.test.js",
    "build:whiteboard": "vite build --config extension/whiteboard/vite.config.mjs",
    "build:notes": "vite build --config extension/notes/vite.config.mjs",
    "build": "npm run build:whiteboard && npm run build:notes"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fishandfly/tab-out.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/fishandfly/tab-out/issues"
  },
  "homepage": "https://github.com/fishandfly/tab-out#readme",
  "private": true,
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@tiptap/extension-table": "^3.7.2",
    "@tiptap/extension-table-cell": "^3.7.2",
    "@tiptap/extension-table-header": "^3.7.2",
    "@tiptap/extension-table-row": "^3.7.2",
    "@tiptap/pm": "^3.7.2",
    "@tiptap/react": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.10"
  }
}
